from googletrans import Translator

def translate_text(text, src_lang, dest_lang):
    translator = Translator()
    translated = translator.translate(text, src=src_lang, dest=dest_lang)
    return translated.text


# -------- RUN PROGRAM --------
print("🌍 Language Translator")
print("Example language codes:")
print("en = English | hi = Hindi | fr = French | es = Spanish | de = German")

text = input("\nEnter text to translate: ")
src = input("Source language code: ")
dest = input("Target language code: ")

result = translate_text(text, src, dest)

print("\n✅ Translated Text:")
print(result)
