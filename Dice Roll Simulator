import random

min_val = 1
max_val = 6

while True:
    print("\nRolling the dice...")
    dice1 = random.randint(min_val, max_val)
    dice2 = random.randint(min_val, max_val)

    print(f"Dice 1: {dice1}")
    print(f"Dice 2: {dice2}")

    choice = input("\nRoll again? (y/n): ").lower()
    if choice != 'y':
        print("Thanks for playing!")
        break
