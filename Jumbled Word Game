import random

# List of words
words = [
    "python", "computer", "science", "machine", "learning",
    "artificial", "intelligence", "programming", "developer", "algorithm"
]

def jumble_word(word):
    word_letters = list(word)
    random.shuffle(word_letters)
    return ''.join(word_letters)

print("🎮 WELCOME TO JUMBLED WORD GAME 🎮")
print("Guess the correct word!")
print("--------------------------------")

while True:
    original_word = random.choice(words)
    jumbled = jumble_word(original_word)

    print(f"\nJumbled Word: {jumbled}")
    guess = input("Your Guess (or type 'exit' to quit): ").lower()

    if guess == "exit":
        print("👋 Thanks for playing!")
        break
    elif guess == original_word:
        print("✅ Correct! Well done 🎉")
    else:
        print(f"❌ Wrong! The correct word was: {original_word}")

    play_again = input("Play again? (yes/no): ").lower()
    if play_again != "yes":
        print("👋 Goodbye! Keep learning 🚀")
        break
